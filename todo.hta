<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta http-equiv="x-ua-compatible" content="ie=edge">
<title>待办事项</title>

<HTA:APPLICATION
  ID="todoWidget"
  APPLICATIONNAME="待办事项"
  BORDER="thin"
  INNERBORDER="no"
  CAPTION="yes"
  SYSMENU="yes"
  MAXIMIZEBUTTON="no"
  MINIMIZEBUTTON="yes"
  SCROLL="no"
  SELECTION="no"
  CONTEXTMENU="no"
  SINGLEINSTANCE="yes"
  NAVIGABLE="no"
/>

<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'PingFang SC', 'Microsoft YaHei', 'Segoe UI', sans-serif;
    color: #3d2c33;
    overflow: hidden;
    height: 100vh;
    display: flex;
    align-items: stretch;
    background: linear-gradient(155deg,
      rgba(252,239,240,0.92) 0%,
      rgba(247,210,213,0.78) 40%,
      rgba(235,159,170,0.40) 70%,
      rgba(192,206,228,0.52) 100%
    );
  }

  .app {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 22px;
    padding: 18px 20px 18px;
    overflow: hidden;
    background: rgba(255,255,255,0.18);
    border: 1px solid rgba(255,255,255,0.35);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.35);
  }

  /* ── Header ── */
  .header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-shrink: 0;
  }
  .header h1 {
    font-size: 26px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: #3d2c33;
    text-shadow: 0 1px 0 rgba(255,255,255,0.6);
  }
  .header .date {
    font-size: 14px;
    color: #7a6570;
    font-weight: 500;
  }

  /* ── Search ── */
  .search-wrap { position: relative; flex-shrink: 0; }
  .search-wrap input {
    width: 100%;
    padding: 10px 14px 10px 36px;
    border: 1.5px solid rgba(192,206,228,0.40);
    border-radius: 18px;
    font-size: 15px;
    outline: none;
    background: rgba(255,255,255,0.50);
    font-family: inherit;
    color: #3d2c33;
    transition: all 0.25s;
    box-shadow: 0 1px 2px rgba(60,30,40,0.04);
  }
  .search-wrap input:focus {
    border-color: rgba(235,159,170,0.5);
    background: rgba(255,255,255,0.72);
    box-shadow: 0 0 0 3px rgba(235,159,170,0.10);
  }
  .search-wrap .search-icon {
    position: absolute; left: 12px; top: 50%;
    transform: translateY(-50%); font-size: 16px;
    color: #b0a0a8; pointer-events: none;
  }

  /* ── Add form ── */
  .add-form {
    background: rgba(255,255,255,0.45);
    border-radius: 16px;
    padding: 18px;
    box-shadow: 0 2px 10px rgba(60,30,40,0.06);
    border: 1px solid rgba(255,255,255,0.40);
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex-shrink: 0;
  }
  .add-form .main-row { display: flex; gap: 12px; }
  .add-form .main-row input[type="text"] {
    flex: 1;
    padding: 10px 16px;
    border: 1.5px solid rgba(192,206,228,0.40);
    border-radius: 22px;
    font-size: 16px;
    outline: none;
    background: rgba(255,255,255,0.52);
    font-family: inherit;
    color: #3d2c33;
    transition: all 0.2s;
  }
  .add-form .main-row input[type="text"]:focus {
    border-color: #EB9FAA;
    background: rgba(255,255,255,0.78);
    box-shadow: 0 0 0 3px rgba(235,159,170,0.10);
  }
  .add-form .main-row input[type="text"]::placeholder { color: #b0a0a8; }
  .btn-add {
    padding: 10px 24px;
    background: linear-gradient(135deg, #EB9FAA 0%, #e08898 100%);
    color: white;
    border: none;
    border-radius: 22px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    font-family: inherit;
    box-shadow: 0 2px 8px rgba(210,110,130,0.22);
  }
  .btn-add:hover { background: #e08898; box-shadow: 0 4px 12px rgba(210,110,130,0.30); }
  .btn-add:active { transform: scale(0.96); }

  .extra-row { display: none; gap: 8px; align-items: center; }
  .extra-row.open { display: flex; }
  .extra-row select, .extra-row input[type="date"] {
    padding: 7px 12px;
    border: 1.5px solid rgba(192,206,228,0.40);
    border-radius: 16px;
    font-size: 13px; outline: none;
    background: rgba(255,255,255,0.52);
    font-family: inherit; color: #7a6570; cursor: pointer;
  }
  .extra-row select:focus, .extra-row input[type="date"]:focus { border-color: #EB9FAA; }
  .btn-more {
    padding: 7px 14px;
    border: 1.5px dashed rgba(192,206,228,0.50);
    background: transparent;
    border-radius: 16px;
    font-size: 13px; cursor: pointer;
    color: #7a6570; font-family: inherit;
    transition: all 0.2s;
  }
  .btn-more:hover { border-color: #EB9FAA; color: #b85060; background: rgba(235,159,170,0.05); }

  /* ── Stats bar ── */
  .stats-bar { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
  .stats-bar .filter-btn {
    padding: 7px 14px;
    border: 1.5px solid rgba(192,206,228,0.32);
    border-radius: 16px;
    font-size: 14px; font-weight: 500;
    cursor: pointer;
    background: rgba(255,255,255,0.45);
    color: #7a6570;
    transition: all 0.2s;
    font-family: inherit;
  }
  .stats-bar .filter-btn:hover { border-color: #EB9FAA; color: #b85060; background: rgba(235,159,170,0.07); }
  .stats-bar .filter-btn.active {
    background: #EB9FAA; color: white; border-color: #EB9FAA;
    box-shadow: 0 2px 6px rgba(210,110,130,0.18);
  }
  .stats-bar .spacer { flex: 1; }
  .stats-bar .count-label { font-size: 14px; color: #7a6570; font-weight: 500; }
  .stats-bar .clear-done {
    padding: 5px 12px; border: none; background: transparent;
    color: #c77a88; font-size: 14px; font-weight: 500;
    cursor: pointer; border-radius: 16px; transition: background 0.2s;
    font-family: inherit; display: none;
  }
  .stats-bar .clear-done:hover { background: rgba(235,159,170,0.10); }

  /* ── Todo list ── */
  .todo-list {
    flex: 1; display: flex; flex-direction: column; gap: 8px;
    overflow-y: auto; overflow-x: hidden; min-height: 50px; padding-right: 3px;
  }
  .todo-list.is-empty::after {
    content: '✨\A\A 添加你的第一个待办事项吧';
    white-space: pre;
    display: flex; align-items: center; justify-content: center;
    height: 110px; color: #b0a0a8; font-size: 13px; font-weight: 500;
    text-align: center; line-height: 1.8;
  }
  .todo-list::-webkit-scrollbar { width: 4px; }
  .todo-list::-webkit-scrollbar-track { background: transparent; }
  .todo-list::-webkit-scrollbar-thumb { background: rgba(192,206,228,0.45); border-radius: 8px; }

  /* ── Todo item ── */
  .todo-item {
    background: rgba(255,255,255,0.48);
    border-radius: 12px; padding: 14px 16px;
    display: flex; align-items: center; gap: 14px;
    transition: all 0.2s;
    border: 1px solid rgba(255,255,255,0.45);
    box-shadow: 0 1px 3px rgba(60,30,40,0.04);
    flex-shrink: 0; cursor: default;
    animation: itemIn 0.3s ease-out;
  }
  @keyframes itemIn {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .todo-item:hover {
    background: rgba(255,255,255,0.74);
    box-shadow: 0 3px 10px rgba(60,30,40,0.07);
  }
  .todo-item.done { opacity: 0.5; }
  .todo-item.done .item-title { text-decoration: line-through; color: #b0a0a8; }
  .todo-item.dragging { opacity: 0.4; transform: scale(0.97); }
  .todo-item.drag-over { border-top: 3px solid #EB9FAA; }

  .check-circle {
    width: 24px; height: 24px; border-radius: 50%;
    border: 2px solid rgba(192,206,228,0.65);
    flex-shrink: 0; cursor: pointer; transition: all 0.25s;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.48);
  }
  .check-circle:hover { border-color: #EB9FAA; transform: scale(1.08); }
  .check-circle.checked {
    background: #8db88d; border-color: #8db88d;
    box-shadow: 0 0 0 3px rgba(141,184,141,0.18);
  }
  .check-circle.checked::after { content: '✓'; color: white; font-size: 14px; font-weight: 700; }

  .item-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .item-title { font-size: 15px; font-weight: 500; word-break: break-word; color: #3d2c33; line-height: 1.4; }
  .item-meta { display: flex; gap: 6px; align-items: center; font-size: 13px; }

  .tag-priority { padding: 2px 9px; border-radius: 12px; font-size: 12px; font-weight: 600; letter-spacing: 0.02em; }
  .pri-high   { background: rgba(235,159,170,0.20); color: #b85060; }
  .pri-medium { background: rgba(192,206,228,0.25); color: #6a7790; }
  .pri-low    { background: rgba(141,184,141,0.18); color: #5a8a5a; }

  .due-label { display: flex; align-items: center; gap: 4px; color: #7a6570; font-size: 13px; }
  .due-label.overdue { color: #d4607a; font-weight: 600; }
  .due-label.today   { color: #c08040; font-weight: 600; }

  /* ── Actions ── */
  .item-actions { display: flex; gap: 1px; flex-shrink: 0; opacity: 0; transition: opacity 0.2s; }
  .todo-item:hover .item-actions { opacity: 1; }
  .item-actions button {
    width: 32px; height: 32px; border: none; background: transparent;
    border-radius: 8px; cursor: pointer; font-size: 16px;
    display: flex; align-items: center; justify-content: center;
    color: #7a6570; transition: all 0.15s;
  }
  .item-actions button:hover { background: rgba(192,206,228,0.22); }
  .item-actions button.del-btn:hover { background: rgba(235,159,170,0.22); color: #b85060; }

  /* ── Edit mode ── */
  .todo-item.editing {
    flex-wrap: wrap; background: rgba(255,255,255,0.76);
    border-color: rgba(235,159,170,0.28);
  }
  .todo-item.editing .item-body { width: 100%; }
  .todo-item.editing .edit-title {
    width: 100%; padding: 7px 10px;
    border: 2px solid #EB9FAA; border-radius: 8px;
    font-size: 14px; outline: none;
    font-family: inherit; background: rgba(255,255,255,0.8);
  }
  .todo-item.editing .edit-meta {
    display: flex; gap: 6px; align-items: center; margin-top: 5px; flex-wrap: wrap;
  }
  .todo-item.editing .edit-meta select,
  .todo-item.editing .edit-meta input[type="date"] {
    padding: 5px 10px; border: 1.5px solid rgba(192,206,228,0.45);
    border-radius: 8px; font-size: 13px; font-family: inherit;
  }
  .todo-item.editing .edit-meta button {
    padding: 5px 14px; border-radius: 8px; border: none;
    font-size: 13px; font-weight: 500; cursor: pointer; font-family: inherit;
  }
  .edit-save { background: #EB9FAA; color: white; }
  .edit-save:hover { background: #d47888; }
  .edit-cancel { background: rgba(192,206,228,0.30); color: #7a6570; }
  .edit-cancel:hover { background: rgba(192,206,228,0.50); }

  .hint { font-size: 13px; color: #b0a0a8; text-align: center; flex-shrink: 0; letter-spacing: 0.02em; }

  .todo-list.rendered .todo-item { animation: none; }
</style>

<script src="todo-core.js"></script>

</head>
<body>

<div class="app">

  <div class="header">
    <h1>待办事项</h1>
    <span class="date" id="currentDate"></span>
  </div>

  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input type="text" id="searchInput" placeholder="搜索待办事项…" autocomplete="off">
  </div>

  <div class="add-form">
    <div class="main-row">
      <input type="text" id="todoInput" placeholder="添加新的待办事项…" maxlength="200" autofocus autocomplete="off">
      <button class="btn-add" id="addBtn">添加</button>
    </div>
    <button class="btn-more" id="btnMore">+ 更多选项</button>
    <div class="extra-row" id="extraRow">
      <input type="date" id="dueDateInput">
      <select id="priorityInput">
        <option value="low">低优先级</option>
        <option value="medium" selected>中优先级</option>
        <option value="high">高优先级</option>
      </select>
      <span style="flex:1;"></span>
      <button class="btn-more" id="btnLess">收起 ▲</button>
    </div>
  </div>

  <div class="stats-bar">
    <button class="filter-btn active" data-filter="all">全部</button>
    <button class="filter-btn" data-filter="active">未完成</button>
    <button class="filter-btn" data-filter="completed">已完成</button>
    <span class="spacer"></span>
    <span class="count-label" id="countLabel"></span>
    <button class="clear-done" id="clearDone">清除已完成</button>
  </div>

  <div class="todo-list is-empty" id="todoList"></div>
  <div class="hint">拖拽排序 · 点击 ✎ 编辑 · 可自由缩放</div>

</div>

<script>
// IE polyfills
if (!Element.prototype.closest) {
  Element.prototype.closest = function(selector) {
    var el = this;
    while (el) {
      if (el.msMatchesSelector ? el.msMatchesSelector(selector) : el.matches(selector)) return el;
      el = el.parentElement;
    }
    return null;
  };
}

(function() {
  'use strict';

  var STORE_KEY = 'dtw_todos_v3';
  var PRI_HIGH   = 'high';
  var PRI_MEDIUM = 'medium';
  var PRI_LOW    = 'low';

  var todos     = [];
  var filter    = 'all';
  var searchQ   = '';
  var editingId = null;
  var searchTimer = null;
  var dragItem  = null;

  var todoInput   = document.getElementById('todoInput');
  var dueDateIn   = document.getElementById('dueDateInput');
  var priorityIn  = document.getElementById('priorityInput');
  var addBtn      = document.getElementById('addBtn');
  var extraRow    = document.getElementById('extraRow');
  var btnMore     = document.getElementById('btnMore');
  var btnLess     = document.getElementById('btnLess');
  var todoList    = document.getElementById('todoList');
  var countLabel  = document.getElementById('countLabel');
  var clearDone   = document.getElementById('clearDone');
  var searchInput = document.getElementById('searchInput');
  var filterBtns  = document.querySelectorAll('.filter-btn');
  var dateEl      = document.getElementById('currentDate');
  window.resizeTo(520, 740);

  (function() {
    var now = new Date();
    var wd = ['日','一','二','三','四','五','六'];
    dateEl.textContent = now.getFullYear() + '年' + (now.getMonth()+1) + '月' + now.getDate() + '日 星期' + wd[now.getDay()];
  })();

  btnMore.addEventListener('click', function() {
    extraRow.classList.add('open');
    btnMore.style.display = 'none';
  });
  btnLess.addEventListener('click', function() {
    extraRow.classList.remove('open');
    btnMore.style.display = '';
  });

  var storage = (function() {
    try {
      if (window.localStorage) {
        window.localStorage.setItem('__test__', '1');
        window.localStorage.removeItem('__test__');
        return window.localStorage;
      }
    } catch(e) {}
    var mem = {};
    return {
      getItem: function(k) { return k in mem ? mem[k] : null; },
      setItem: function(k, v) { mem[k] = v; }
    };
  })();

  function loadTodos() {
    try { var r = storage.getItem(STORE_KEY); todos = r ? JSON.parse(r) : []; }
    catch(e) { todos = []; }
  }
  function saveTodos() { storage.setItem(STORE_KEY, JSON.stringify(todos)); }
  function commit() { saveTodos(); render(); }

  // ── Render ──
  function render() {
    var list = TC.filterTodos(todos, filter, searchQ);
    var activeN = 0, doneN = 0, i;
    for (i = 0; i < todos.length; i++) {
      if (todos[i].completed) doneN++; else activeN++;
    }
    countLabel.textContent = activeN + ' 项待完成';
    clearDone.style.display = doneN > 0 ? '' : 'none';

    if (list.length === 0) { todoList.classList.add('is-empty'); }
    else { todoList.classList.remove('is-empty'); }

    var todayMs = TC.getTodayMs();
    var html = '';
    for (i = 0; i < list.length; i++) {
      html += (list[i].id === editingId) ? renderEdit(list[i]) : renderItem(list[i], todayMs, i);
    }
    todoList.innerHTML = html;
  }

  function renderItem(t, todayMs, idx) {
    var di = TC.dueInfo(t.dueDate, todayMs);
    var delay = idx * 0.03;
    var cls = 'todo-item' + (t.completed ? ' done' : '');
    return '<div class="' + cls + '" data-id="' + t.id + '" draggable="true" style="animation-delay:' + delay + 's;">' +
      '<div class="check-circle' + (t.completed ? ' checked' : '') + '"></div>' +
      '<div class="item-body">' +
        '<span class="item-title">' + TC.esc(t.title) + '</span>' +
        '<div class="item-meta">' +
          '<span class="tag-priority pri-' + t.priority + '">' + TC.PRI_LABELS[t.priority] + '</span>' +
          (di ? '<span class="due-label ' + di.cls + '">📅 ' + di.label + '</span>' : '') +
        '</div>' +
      '</div>' +
      '<div class="item-actions">' +
        '<button title="编辑">✎</button>' +
        '<button class="del-btn" title="删除">✕</button>' +
      '</div>' +
    '</div>';
  }

  function renderEdit(t) {
    var dueVal = t.dueDate || '';
    return '<div class="todo-item editing" data-id="' + t.id + '">' +
      '<div class="item-body">' +
        '<input class="edit-title" value="' + TC.esc(t.title) + '" data-field="title">' +
        '<div class="edit-meta">' +
          '<select data-field="priority">' +
            '<option value="' + PRI_HIGH   + '"' + (t.priority===PRI_HIGH  ?' selected':'') + '>高优先级</option>' +
            '<option value="' + PRI_MEDIUM + '"' + (t.priority===PRI_MEDIUM?' selected':'') + '>中优先级</option>' +
            '<option value="' + PRI_LOW    + '"' + (t.priority===PRI_LOW   ?' selected':'') + '>低优先级</option>' +
          '</select>' +
          '<input type="date" value="' + dueVal + '" data-field="dueDate">' +
          '<span style="flex:1;"></span>' +
          '<button class="edit-save">保存</button>' +
          '<button class="edit-cancel">取消</button>' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  function find(id) {
    for (var i = 0; i < todos.length; i++) { if (todos[i].id === id) return todos[i]; }
    return null;
  }

  // ── Actions ──
  function addTodo() {
    var title = todoInput.value.trim();
    if (!title) return;
    todos.unshift({
      id: TC.uid(), title: title, completed: false,
      priority: priorityIn.value,
      dueDate: dueDateIn.value || null
    });
    todoInput.value = '';
    dueDateIn.value = '';
    priorityIn.value = PRI_MEDIUM;
    commit();
    todoInput.focus();
  }

  function toggleItem(id) {
    var t = find(id); if (t) { t.completed = !t.completed; commit(); }
  }
  function deleteItem(id) {
    todos = todos.filter(function(t){ return t.id !== id; });
    if (editingId === id) editingId = null;
    commit();
  }

  function clearDragOvers() {
    var overs = todoList.querySelectorAll('.drag-over');
    for (var i = 0; i < overs.length; i++) overs[i].classList.remove('drag-over');
  }

  todoList.addEventListener('click', function(e) {
    var el = e.target;
    var item = el.closest('.todo-item');
    if (!item) return;
    var id = item.getAttribute('data-id');

    if (el.classList.contains('check-circle')) { toggleItem(id); return; }
    if (el.closest('.del-btn')) { deleteItem(id); return; }
    if (el.classList.contains('edit-cancel')) { editingId = null; render(); return; }

    if (el.classList.contains('edit-save')) {
      var t = find(id);
      if (!t) return;
      var titleIn = item.querySelector('[data-field="title"]');
      var priIn   = item.querySelector('[data-field="priority"]');
      var dateIn  = item.querySelector('[data-field="dueDate"]');
      if (!(titleIn && titleIn.value.trim())) return;
      t.title    = titleIn.value.trim();
      t.priority = priIn.value;
      t.dueDate  = dateIn.value || null;
      editingId  = null;
      commit();
      return;
    }

    var actBtn = el.closest('.item-actions button');
    if (actBtn && !actBtn.classList.contains('del-btn')) {
      editingId = id; render(); focusEdit(id);
    }
  });

  function focusEdit(id) {
    setTimeout(function() {
      var inp = document.querySelector('[data-id="' + id + '"] .edit-title');
      if (inp) { inp.focus(); inp.select(); }
    }, 30);
  }

  todoList.addEventListener('keydown', function(e) {
    if (!e.target.classList.contains('edit-title')) return;
    if ((e.keyCode || e.which) === 13) {
      var item = e.target.closest('.todo-item');
      if (item) { var sb = item.querySelector('.edit-save'); if (sb) sb.click(); }
    }
    if ((e.keyCode || e.which) === 27) { editingId = null; render(); }
  });

  addBtn.addEventListener('click', addTodo);
  todoInput.addEventListener('keydown', function(e) {
    if ((e.keyCode || e.which) === 13) addTodo();  // Enter
  });

  // ── Search ──
  searchInput.addEventListener('input', function() {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(function() { searchQ = searchInput.value.trim(); render(); }, 180);
  });

  for (var j = 0; j < filterBtns.length; j++) {
    filterBtns[j].addEventListener('click', function() {
      var newFilter = this.getAttribute('data-filter');
      if (filter === newFilter) return;
      for (var k = 0; k < filterBtns.length; k++) filterBtns[k].classList.remove('active');
      this.classList.add('active');
      filter = newFilter;
      render();
    });
  }

  clearDone.addEventListener('click', function() {
    todos = todos.filter(function(t){ return !t.completed; });
    commit();
  });

  todoList.addEventListener('dragstart', function(e) {
    var item = e.target.closest('.todo-item');
    if (!item || item.classList.contains('editing')) { e.preventDefault(); return; }
    dragItem = item;
    item.classList.add('dragging');
    e.dataTransfer.effectAllowed = 'move';
  });
  todoList.addEventListener('dragend', function() {
    if (dragItem) dragItem.classList.remove('dragging');
    clearDragOvers();
    dragItem = null;
  });
  todoList.addEventListener('dragover', function(e) {
    e.preventDefault();
    var tgt = e.target.closest('.todo-item');
    if (!tgt || tgt === dragItem || tgt.classList.contains('editing')) return;
    e.dataTransfer.dropEffect = 'move';
    clearDragOvers();
    tgt.classList.add('drag-over');
  });
  todoList.addEventListener('drop', function(e) {
    e.preventDefault();
    var tgt = e.target.closest('.todo-item');
    if (!tgt || tgt === dragItem || tgt.classList.contains('editing')) return;
    var sid = dragItem.getAttribute('data-id');
    var tid = tgt.getAttribute('data-id');
    var si = -1, ti = -1;
    for (var i = 0; i < todos.length; i++) {
      if (todos[i].id === sid) si = i;
      if (todos[i].id === tid) { ti = i; break; }
    }
    if (si !== -1 && ti !== -1) {
      var moved = todos.splice(si, 1)[0];
      todos.splice(ti, 0, moved);
      commit();
    }
  });

  // ── Init ──
  loadTodos();
  render();
  todoList.classList.add('rendered');
  todoInput.focus();
})();
</script>

</body>
</html>
